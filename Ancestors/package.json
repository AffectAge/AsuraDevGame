{
  "name": "ancestors-hex-terrain",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --host 127.0.0.1 --port 5273",
    "dev:server": "tsx watch server/src/index.ts",
    "build": "tsc && vite build",
    "test": "vitest run --config vitest.config.ts",
    "start": "node dist-server/index.js"
  },
  "dependencies": {
    "@babylonjs/core": "^8.9.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.10",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "vitest": "^3.2.4"
  }
}
